{
  "name": "nano-banana-studio",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "node scripts/build-installer.js",
    "dist:win": "node scripts/build-installer.js --win",
    "dist:mac": "node scripts/build-installer.js --mac",
    "dist:linux": "node scripts/build-installer.js --linux"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "heic-convert": "^2.1.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "next": "15.3.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.nanobanana.studio",
    "productName": "Nano Banana Studio",
    "copyright": "Copyright © 2025 iSupply",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon1.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon1.ico",
      "uninstallerIcon": "public/icon1.ico",
      "installerHeaderIcon": "public/icon1.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nano Banana Studio",
      "license": "LICENSE.txt"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Graphics"
    }
  }
}
